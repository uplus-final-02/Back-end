{
  "max_ngram_diff": 20,
  "analysis": {
    "tokenizer": {
      "nori_custom_tokenizer": {
        "type": "nori_tokenizer",
        "decompound_mode": "mixed"
      },
      "edge_ngram_tokenizer": {
        "type": "edge_ngram",
        "min_gram": 1,
        "max_gram": 20,
        "token_chars": ["letter", "digit"]
      }
    },
    "analyzer": {
      "nori_analyzer": {
        "type": "custom",
        "tokenizer": "nori_custom_tokenizer",
        "filter": ["lowercase", "nori_readingform"]
      },
      "autocomplete_analyzer": {
        "type": "custom",
        "tokenizer": "edge_ngram_tokenizer",
        "filter": ["lowercase"]
      },
      "lowercase_analyzer": {
        "type": "custom",
        "tokenizer": "standard",
        "filter": ["lowercase"]
      }
    }
  }
}